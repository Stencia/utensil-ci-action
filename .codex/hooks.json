{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "^(Bash|exec_command|functions\\.exec_command)$",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$(git rev-parse --show-toplevel)/.codex/hooks/prevent_pr_merge.py\"",
            "timeout": 10,
            "statusMessage": "Checking PR merge guardrail"
          }
        ]
      }
    ]
  }
}
